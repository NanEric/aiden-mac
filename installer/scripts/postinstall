#!/bin/bash
set -euo pipefail

APP_NAME="Aiden"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LOCK_FILE="$SCRIPT_DIR/manifests/dependency-lock.json"
RUNTIME_PLIST_SRC="$SCRIPT_DIR/manifests/com.aiden.runtimeagent.plist"
TRAY_PLIST_SRC="$SCRIPT_DIR/manifests/com.aiden.tray.plist"
COLLECTOR_TEMPLATE="$SCRIPT_DIR/third_party/collector/config.yaml.template"
AGENT_BOOTSTRAP_PATH="/Library/Application Support/Aiden/bootstrap/AidenRuntimeAgent"
TRAY_BINARY_PATH="/Applications/AidenTrayMac.app/Contents/MacOS/AidenTrayMac"

console_user=$(stat -f '%Su' /dev/console 2>/dev/null || echo "")
if [[ -z "$console_user" || "$console_user" == "root" ]]; then
  echo "Unable to detect logged-in user for LaunchAgent installation" >&2
  exit 1
fi

user_home=$(dscl . -read "/Users/$console_user" NFSHomeDirectory | awk '{print $2}')
if [[ -z "$user_home" || ! -d "$user_home" ]]; then
  echo "Unable to resolve home directory for user: $console_user" >&2
  exit 1
fi

AIDEN_ROOT="$user_home/Library/Application Support/$APP_NAME"
BIN_BASE="$AIDEN_ROOT/bin"
RUNTIME_BASE="$AIDEN_ROOT/runtime"
CONFIG_BASE="$AIDEN_ROOT/config"
LOG_BASE="$user_home/Library/Logs/$APP_NAME"
LAUNCH_AGENT_DIR="$user_home/Library/LaunchAgents"
RUNTIME_LAUNCH_AGENT="$LAUNCH_AGENT_DIR/com.aiden.runtimeagent.plist"
TRAY_LAUNCH_AGENT="$LAUNCH_AGENT_DIR/com.aiden.tray.plist"
AGENT_BINARY_PATH="$BIN_BASE/AidenRuntimeAgent"

VERSION=$(python3 -c 'import json,sys;print(json.load(open(sys.argv[1]))["version"])' "$LOCK_FILE")
TARGET_DIR="$RUNTIME_BASE/$VERSION"
CURRENT_LINK="$RUNTIME_BASE/current"
VM_DATA_PATH="$CURRENT_LINK/data/victoria-metrics"
TMP_DIR=$(mktemp -d)

cleanup() {
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT

ensure_user_ownership() {
  chown -R "$console_user":staff "$AIDEN_ROOT" "$LOG_BASE"
  chmod 755 "$AIDEN_ROOT" "$BIN_BASE" "$RUNTIME_BASE" "$CONFIG_BASE" "$LOG_BASE"
}

mkdir -p "$BIN_BASE" "$TARGET_DIR/bin" "$TARGET_DIR/config" "$TARGET_DIR/data/victoria-metrics" "$CONFIG_BASE" "$LOG_BASE" "$LAUNCH_AGENT_DIR"
ensure_user_ownership

if [[ ! -x "$AGENT_BOOTSTRAP_PATH" ]]; then
  echo "Missing bootstrap agent binary: $AGENT_BOOTSTRAP_PATH" >&2
  exit 1
fi

install -m 755 "$AGENT_BOOTSTRAP_PATH" "$AGENT_BINARY_PATH"

validate_lock_file() {
  local invalid
  invalid=$(python3 - "$LOCK_FILE" <<'PY'
import json,sys,re
with open(sys.argv[1], 'r', encoding='utf-8') as f:
    lock = json.load(f)
for name in ("otelcol", "victoriaMetrics"):
    a = lock["artifacts"][name]
    if "REPLACE_WITH_" in a["sha256"]:
        print("placeholder")
        raise SystemExit(1)
    if not a["url"].startswith("https://"):
        print("url")
        raise SystemExit(1)
    if not re.fullmatch(r"[a-fA-F0-9]{64}", a["sha256"]):
        print("sha")
        raise SystemExit(1)
    team = a.get("teamId", "")
    if team and not re.fullmatch(r"[A-Z0-9]{10}", team):
        print("team")
        raise SystemExit(1)
print("ok")
PY
) || true

  if [[ "$invalid" != "ok" ]]; then
    echo "dependency-lock.json is invalid or still contains placeholders" >&2
    exit 1
  fi
}

write_collector_config() {
  cp "$COLLECTOR_TEMPLATE" "$TARGET_DIR/config/collector.yaml"
}

fetch_and_verify() {
  local key="$1"
  local sha team binary archive output extracted
  sha=$(python3 -c 'import json,sys;d=json.load(open(sys.argv[1]));print(d["artifacts"][sys.argv[2]]["sha256"])' "$LOCK_FILE" "$key")
  team=$(python3 -c 'import json,sys;d=json.load(open(sys.argv[1]));print(d["artifacts"][sys.argv[2]]["teamId"])' "$LOCK_FILE" "$key")
  binary=$(python3 -c 'import json,sys;d=json.load(open(sys.argv[1]));print(d["artifacts"][sys.argv[2]]["binary"])' "$LOCK_FILE" "$key")

  archive="$TMP_DIR/$key.tar.gz"
  output="$TARGET_DIR/bin/$binary"

  local actual_sha
  actual_sha=$(shasum -a 256 "$archive" | awk '{print $1}')
  if [[ "$actual_sha" != "$sha" ]]; then
    echo "SHA256 mismatch for $key" >&2
    exit 1
  fi

  tar -xzf "$archive" -C "$TMP_DIR"
  extracted="$TMP_DIR/$binary"
  if [[ ! -f "$extracted" ]]; then
    echo "Archive for $key does not contain expected binary: $binary" >&2
    exit 1
  fi

  mv "$extracted" "$output"
  chmod 755 "$output"

  if [[ -n "$team" ]]; then
    if ! codesign -dv --verbose=4 "$output" 2>&1 | grep -q "TeamIdentifier=$team"; then
      echo "Team ID mismatch for $key" >&2
      exit 1
    fi
    if ! spctl -a -t exec -vv "$output" >/dev/null 2>&1; then
      echo "Gatekeeper assessment failed for $key" >&2
      exit 1
    fi
  else
    codesign -dv --verbose=4 "$output" >/dev/null 2>&1 || true
  fi
}

download_artifact() {
  local key="$1"
  local url archive
  url=$(python3 -c 'import json,sys;d=json.load(open(sys.argv[1]));print(d["artifacts"][sys.argv[2]]["url"])' "$LOCK_FILE" "$key")
  archive="$TMP_DIR/$key.tar.gz"
  curl --fail --location --retry 2 --retry-delay 2 --connect-timeout 15 "$url" --output "$archive"
}

validate_lock_file
# Download in parallel to stay under macOS installer script timeout (about 600s).
download_artifact "otelcol" &
pid_otel=$!
download_artifact "victoriaMetrics" &
pid_vm=$!

if ! wait $pid_otel; then
  echo "Failed to download otelcol artifact" >&2
  exit 1
fi

if ! wait $pid_vm; then
  echo "Failed to download victoriaMetrics artifact" >&2
  exit 1
fi

fetch_and_verify "otelcol"
fetch_and_verify "victoriaMetrics"
write_collector_config

ln -sfn "$TARGET_DIR" "$CURRENT_LINK"

cat > "$CONFIG_BASE/runtime.shared.json" <<JSON
{
  "agent": { "host": "127.0.0.1", "port": 18777 },
  "runtime": {
    "rootPath": "$CURRENT_LINK",
    "vmPath": "bin/victoria-metrics-prod",
    "collectorPath": "bin/otelcol",
    "vmArgs": ["-retentionPeriod=30d", "-httpListenAddr=:18428", "-storageDataPath", "$VM_DATA_PATH"],
    "collectorArgs": ["--config", "$CURRENT_LINK/config/collector.yaml"]
  },
  "polling": { "seconds": 5 }
}
JSON

cp "$RUNTIME_PLIST_SRC" "$RUNTIME_LAUNCH_AGENT"
cp "$TRAY_PLIST_SRC" "$TRAY_LAUNCH_AGENT"

/usr/libexec/PlistBuddy -c "Set :ProgramArguments:0 $AGENT_BINARY_PATH" "$RUNTIME_LAUNCH_AGENT"
/usr/libexec/PlistBuddy -c "Set :EnvironmentVariables:AIDEN_CONFIG_PATH $CONFIG_BASE/runtime.shared.json" "$RUNTIME_LAUNCH_AGENT"
/usr/libexec/PlistBuddy -c "Set :StandardOutPath $LOG_BASE/runtimeagent.out.log" "$RUNTIME_LAUNCH_AGENT"
/usr/libexec/PlistBuddy -c "Set :StandardErrorPath $LOG_BASE/runtimeagent.err.log" "$RUNTIME_LAUNCH_AGENT"

/usr/libexec/PlistBuddy -c "Set :ProgramArguments:0 $TRAY_BINARY_PATH" "$TRAY_LAUNCH_AGENT"
/usr/libexec/PlistBuddy -c "Set :StandardOutPath $LOG_BASE/tray.out.log" "$TRAY_LAUNCH_AGENT"
/usr/libexec/PlistBuddy -c "Set :StandardErrorPath $LOG_BASE/tray.err.log" "$TRAY_LAUNCH_AGENT"

uid=$(id -u "$console_user")
chown "$console_user":staff "$RUNTIME_LAUNCH_AGENT" "$TRAY_LAUNCH_AGENT"
chmod 644 "$RUNTIME_LAUNCH_AGENT" "$TRAY_LAUNCH_AGENT"
ensure_user_ownership

# Installer stage only cleans stale jobs. It does not start new jobs.
launchctl asuser "$uid" launchctl bootout "gui/$uid/com.aiden.runtimeagent" >/dev/null 2>&1 || true
launchctl asuser "$uid" launchctl bootout "gui/$uid/com.aiden.tray" >/dev/null 2>&1 || true

exit 0
