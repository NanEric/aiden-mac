<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.aiden.tray</string>
  <key>ProgramArguments</key>
  <array>
    <string>__AIDEN_TRAY_BIN__</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__AIDEN_LOG_DIR__/tray.out.log</string>
  <key>StandardErrorPath</key>
  <string>__AIDEN_LOG_DIR__/tray.err.log</string>
</dict>
</plist>
