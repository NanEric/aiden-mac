receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 127.0.0.1:4317

processors:
  batch: {}

exporters:
  prometheusremotewrite:
    endpoint: http://127.0.0.1:18428/api/v1/write
  file/codex:
    path: __CODEX_LOG_PATH__
    format: json
  nop: {}

service:
  pipelines:
    metrics:
      receivers: [otlp]
      processors: [batch]
      exporters: [prometheusremotewrite]
    logs:
      receivers: [otlp]
      processors: [batch]
      exporters: [file/codex]
    traces:
      receivers: [otlp]
      processors: [batch]
      exporters: [nop]
